<module configVersion="1.2">
	
	<!-- Base Module Properties -->
	<id>${project.parent.artifactId}</id>
	<name>${project.parent.name}</name>
	<version>${project.parent.version}</version>
	<package>org.openmrs.module.auditlogweb</package>
	<author>wikum</author>
	<description>
			${project.parent.description}
	</description>

	<activator>org.openmrs.module.auditlogweb.AuditlogwebActivator</activator>

	<require_version>2.7.0</require_version>
	
	<!-- Extensions -->
	<extension>
		<point>org.openmrs.admin.list</point>
		<class>org.openmrs.module.auditlogweb.extension.html.AdminList</class>
	</extension>

	<aware_of_modules>
		<aware_of_module>org.openmrs.module.legacyui</aware_of_module>
	</aware_of_modules>

	<privileges>
		<privilege>
			<name>View Audit Logs</name>
			<description>Allows viewing audit logs in the system</description>
		</privilege>
		<privilege>
			<name>View Security Audit Logs</name>
			<description>Allows viewing security audit logs</description>
		</privilege>
	</privileges>

	<globalProperty>
		<property>auditlogweb.backfillExistingData.enabled</property>
		<defaultValue>true</defaultValue>
		<description>
			When set to true, the module performs a one-time backfill on startup: it snapshots the
			current contents of every Envers-audited table into its corresponding audit table.
			Requires hibernate.integration.envers.enabled=true.
			Runs only once (see auditlogweb.backfillExistingData.completed).
		</description>
	</globalProperty>
	<globalProperty>
		<property>auditlogweb.backfillExistingData.completed</property>
		<defaultValue>false</defaultValue>
		<description>
			Marker set automatically to true after the one-time existing-data backfill has run
			successfully. Reset it to false to allow the backfill to run again on the next startup.
		</description>
	</globalProperty>

	<messages>
		<lang>en</lang>
		<file>messages.properties</file>
	</messages>
	<messages>
		<lang>fr</lang>
		<file>messages_fr.properties</file>
	</messages>
	<messages>
		<lang>es</lang>
		<file>messages_es.properties</file>
	</messages>
	<!-- /Internationalization -->
	<!-- Servlet filter: captures IP, User-Agent, session into ThreadLocal on every request -->
	<filter>
		<filter-name>auditContextFilter</filter-name>
		<filter-class>org.openmrs.module.auditlogweb.web.AuditContextFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>auditContextFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

</module>

